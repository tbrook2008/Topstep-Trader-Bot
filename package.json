{
  "name": "ai-trader",
  "version": "1.0.0",
  "description": "Autonomous AI Quantitative Trading System — Tri-Node Consensus",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "node --watch server/index.js",
    "loop": "node server/autonomous/scheduler.js",
    "test:data": "node -e \"require('./server/data/yahooFinance').getQuote('AAPL').then(r => console.log(JSON.stringify(r,null,2))).catch(console.error)\"",
    "test:db": "node -e \"require('./server/db/schema').initDb(); console.log('✅ DB initialized')\"",
    "test:kelly": "node -e \"const k=require('./server/risk/kellyCriterion'); console.log(k.calculate({winRate:0.6,avgWin:0.05,avgLoss:0.03,balance:100000}))\"",
    "test:ollama": "node -e \"require('./server/ai/ollamaNode').test().then(console.log).catch(console.error)\"",
    "dry-run": "DRY_RUN=true node server/autonomous/loop.js"
  },
  "dependencies": {
    "@alpacahq/alpaca-trade-api": "^3.1.3",
    "@google/generative-ai": "^0.21.0",
    "axios": "^1.7.2",
    "better-sqlite3": "^9.4.3",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "node-cron": "^3.0.3",
    "rss-parser": "^3.13.0",
    "winston": "^3.13.0",
    "yahoo-finance2": "^2.11.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
