# ============================================================
#  AI TRADER — Environment Configuration
#  Copy this file to .env and fill in your values
#  DO NOT commit .env to Git
# ============================================================

# --- Optional: Polygon.io (technical indicators only) ---
POLYGON_API_KEY=

# --- Google AI Studio (Gemini) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# --- Ollama (local on Windows desktop) ---
OLLAMA_DESKTOP_IP=localhost
OLLAMA_PORT=11434
OLLAMA_MODEL=llama3
# ^ Run "ollama list" in PowerShell on your desktop to confirm model name

# --- DeepSeek ---
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# --- Alpaca Trading ---
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_PAPER_URL=https://paper-api.alpaca.markets
ALPACA_LIVE_URL=https://api.alpaca.markets
# Set to "paper" or "live" — ALWAYS start with paper
TRADING_MODE=paper

# --- AI Consensus Weights (must sum to 1.0) ---
WEIGHT_GEMINI=0.40
WEIGHT_OLLAMA=0.25
WEIGHT_DEEPSEEK=0.35
APPROVAL_THRESHOLD=55

# --- Account Balances ---
PAPER_ACCOUNT_BALANCE=100000
LIVE_ACCOUNT_BALANCE=5000

# --- Risk Management ---
MAX_POSITION_PCT=0.10
STOP_LOSS_PCT=0.02
KELLY_FRACTION_DIVISOR=4
MIN_KELLY_FRACTION=0.005
MAX_KELLY_FRACTION=0.15
MIN_AI_CONFIDENCE=55
MAX_DAILY_LOSS_PCT=0.05
MAX_CONSECUTIVE_LOSSES=3
COOLDOWN_MINUTES=30

# --- Autonomous Loop ---
CRON_SCHEDULE=*/15 * * * *
WATCHED_SYMBOLS=AAPL,TSLA,SPY,BTC-USD,ETH-USD

# --- Server ---
PORT=3000

# --- Security ---
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
LOG_HMAC_SECRET=change_this_to_a_random_64_char_hex_string
